{
  "name": "openclaw-guild",
  "version": "0.1.1",
  "description": "OpenClaw Guild plugin — Supabase-backed memory, skills, and per-agent auth for multi-user agent teams",
  "type": "module",
  "main": "dist/index.js",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": "1"
    },
    "build": {
      "openclawVersion": "2026.3.24"
    },
    "requiredConfig": {
      "supabaseUrl": "Supabase REST API URL (e.g. http://localhost:54321 or hosted)",
      "supabaseAnonKey": "Supabase anonymous/public key for RLS-enforced queries"
    },
    "optionalConfig": {
      "supabaseServiceKey": "Service role key for CLI admin operations (agent provisioning). Not required at runtime."
    },
    "access": {
      "gatewayEnv": true,
      "filesystem": [
        "session JSONL transcripts (read-only, before_compaction hook)"
      ],
      "network": [
        "Supabase REST API (PostgREST + Auth)"
      ],
      "hooks": [
        "before_prompt_build",
        "before_compaction",
        "agent_end"
      ],
      "tools": [
        "guild_memory_read",
        "guild_memory_save",
        "guild_memory_archive",
        "guild_memory_search",
        "guild_memory_team",
        "guild_memory_company",
        "guild_skill_read",
        "guild_skill_list",
        "guild_skill_save",
        "guild_user_read",
        "guild_user_save"
      ]
    },
    "privacy": {
      "readsUserMessages": true,
      "writesToExternalService": "Supabase (user-configured, self-hosted or cloud)",
      "autoCapture": "Extracts user facts from conversations (opt-out via auto_capture_enabled per user)",
      "credentialStorage": "Agent email/password in plugin config, supports $ENV_VAR references"
    }
  },
  "files": [
    "dist/**/*.js",
    "openclaw.plugin.json",
    "package.json",
    "README.md",
    "LICENSE",
    "INSTALL.md"
  ],
  "scripts": {
    "build": "npx tsc",
    "check": "npx tsc --noEmit",
    "prepublishOnly": "npx tsc"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.0"
  },
  "devDependencies": {
    "openclaw": "2026.3.24",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.24"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "memory",
    "skills",
    "supabase",
    "multi-user",
    "rbac",
    "agent"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/SpireTech/openclaw-guild.git",
    "directory": "packages/plugin"
  },
  "homepage": "https://github.com/SpireTech/openclaw-guild#readme",
  "license": "AGPL-3.0-or-later"
}
